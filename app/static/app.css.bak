:root {
  color-scheme: dark;
  --bg: #0c1220;
  --panel: #121b2d;
  --panel-2: #16233a;
  --border: #223353;
  --text: #eef4ff;
  --muted: #9eb1cf;
  --accent: #4f8cff;
  --accent-2: #2f6fe4;
  --danger: #ef6b73;
  --success: #4ac6a8;
  --chip: #1c2944;
  --shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
}

* { box-sizing: border-box; }
html, body { height: 100%; overflow: hidden; }
body {
  margin: 0;
  font-family: Inter, Arial, Helvetica, sans-serif;
  background: linear-gradient(180deg, #0b1120 0%, #0e1628 100%);
  color: var(--text);
}
button, input, textarea, select { font: inherit; color: inherit; }
button { cursor: pointer; }
pre {
  margin: 0;
  padding: 12px 14px;
  white-space: pre-wrap;
  word-break: break-word;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 13px;
  line-height: 1.5;
}
.app-shell { height: 100vh; padding: 14px; overflow: hidden; }
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 12px;
}
.eyebrow {
  color: #8fb3ff;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 12px;
  font-weight: 700;
}
h1, h2, h3, p { margin: 0; }
h1 { font-size: 30px; margin-top: 4px; }
h2 { font-size: 20px; }
.page-grid {
  display: grid;
  grid-template-columns: 230px minmax(0, 1.55fr) minmax(360px, 0.85fr);
  gap: 14px;
  height: calc(100vh - 90px);
}
.panel {
  background: rgba(18, 27, 45, 0.92);
  border: 1px solid var(--border);
  border-radius: 20px;
  box-shadow: var(--shadow);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
}
.panel-header {
  padding: 16px 18px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  background: rgba(18, 27, 45, 0.98);
}
.sticky { position: sticky; top: 0; z-index: 3; }
.muted { color: var(--muted); margin-top: 6px; line-height: 1.45; }
button, .secondary {
  border-radius: 12px;
}
button {
  background: linear-gradient(180deg, var(--accent) 0%, var(--accent-2) 100%);
  color: white;
  border: none;
  padding: 11px 14px;
  font-weight: 700;
}
button.secondary {
  background: var(--panel-2);
  border: 1px solid var(--border);
}
button:disabled { opacity: 0.45; cursor: not-allowed; }
input, textarea {
  background: #0f1728;
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 10px 12px;
}
.session-list, .chat-thread {
  padding: 12px;
  overflow: auto;
  min-height: 0;
}
.session-list { display: flex; flex-direction: column; gap: 8px; }
.session-card, .message {
  width: 100%;
  text-align: left;
  background: #10192b;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 16px;
}
.session-card { padding: 12px; }
.session-card.active {
  border-color: rgba(79,140,255,0.65);
  background: linear-gradient(180deg, rgba(20, 32, 52, 0.98) 0%, rgba(15, 25, 42, 0.98) 100%);
  box-shadow: 0 0 0 1px rgba(79,140,255,0.18) inset;
}
.session-card:hover,
button.secondary:hover { opacity: 0.96; }
.session-compact-top,
.session-compact-meta,
.session-compact-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  min-width: 0;
}
.session-title-wrap {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10px;
}
.session-health {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  flex: 0 0 auto;
  box-shadow: 0 0 0 4px rgba(255,255,255,0.04);
}
.session-health.ok { background: var(--success); }
.session-health.fail { background: var(--danger); }
.session-title {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.session-status-text {
  flex: 0 0 auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 24px;
  padding: 4px 9px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.02em;
  white-space: nowrap;
}
.session-status-text.ok { background: rgba(74, 198, 168, 0.14); color: #80f0d4; }
.session-status-text.fail { background: rgba(239, 107, 115, 0.14); color: #ffb6bc; }
.session-compact-meta { margin-top: 7px; color: var(--muted); font-size: 12px; }
.session-host {
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 12px;
}
.session-updated, .session-stats { color: var(--muted); font-size: 12px; white-space: nowrap; }
.session-compact-footer { margin-top: 8px; justify-content: flex-end; }
.event-stream {
  flex: 1;
  overflow: auto;
  min-height: 0;
  padding: 16px;
}
.event-stream-items {
  display: flex;
  flex-direction: column;
  gap: 12px;
  min-height: 100%;
}
.stream-loader {
  position: sticky;
  top: 0;
  z-index: 2;
  margin: 0 auto 12px;
  width: fit-content;
  padding: 8px 12px;
  border-radius: 999px;
  font-size: 12px;
  color: #d7e5ff;
  background: rgba(28, 41, 68, 0.95);
  border: 1px solid rgba(255,255,255,0.08);
}
.hidden { display: none; }
.timeline-event {
  border-radius: 16px;
  background: #10192b;
  border: 1px solid rgba(255,255,255,0.06);
  overflow: hidden;
}
.timeline-event-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  padding: 14px 14px 4px;
}
.timeline-event-time {
  font-weight: 700;
  font-size: 14px;
}
.timeline-event-sub {
  color: var(--muted);
  font-size: 12px;
  margin-top: 4px;
}
.block-label {
  font-size: 12px;
  font-weight: 700;
  color: #adc4ed;
  padding: 8px 14px;
  border-top: 1px solid rgba(255,255,255,0.05);
  border-bottom: 1px solid rgba(255,255,255,0.05);
  background: rgba(11, 18, 32, 0.65);
}
.timeline-cmd,
.timeline-output,
.timeline-meta-block {
  background: #0b1220;
}
.timeline-details summary {
  cursor: pointer;
  padding: 12px 14px;
  color: #b7c9e7;
}
.timeline-meta-empty {
  color: var(--muted);
}
.empty-state {
  color: var(--muted);
  display: grid;
  place-items: center;
  min-height: 160px;
  text-align: center;
}
.chat-panel { overflow: hidden; }
.chat-thread {
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1 1 auto;
  min-height: 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  padding: 16px;
}
.message { padding: 14px; max-width: 100%; }
.message.user { align-self: flex-end; background: rgba(79,140,255,0.18); }
.message.assistant { align-self: flex-start; }
.message.pending { opacity: 0.95; }
.message.error { border-color: rgba(239, 107, 115, 0.35); }
.message-top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
}
.message-time, .message-tools { color: var(--muted); font-size: 13px; }
.message-tools {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: 999px;
  padding: 5px 10px;
  background: var(--chip);
  color: #d7e5ff;
  margin-top: 10px;
}
.message-body { line-height: 1.6; margin-top: 10px; }
.plain-body { white-space: pre-wrap; }
.markdown-body { white-space: normal; }
.markdown-body > *:first-child { margin-top: 0; }
.markdown-body > *:last-child { margin-bottom: 0; }
.markdown-body p { margin: 0 0 12px; }
.markdown-body ul,
.markdown-body ol { margin: 8px 0 12px 20px; padding: 0; }
.markdown-body li + li { margin-top: 6px; }
.markdown-body h1, .markdown-body h2, .markdown-body h3 { margin: 14px 0 10px; line-height: 1.3; }
.markdown-body h1 { font-size: 24px; }
.markdown-body h2 { font-size: 21px; }
.markdown-body h3 { font-size: 18px; }
.markdown-body code {
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 8px;
  padding: 2px 6px;
  font-size: 0.95em;
}
.markdown-body .md-code {
  margin: 12px 0;
  background: #0b1220;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  overflow: auto;
}
.markdown-body .md-code code {
  display: block;
  padding: 12px 14px;
  background: transparent;
  border: none;
  border-radius: 0;
  white-space: pre-wrap;
  word-break: break-word;
}
.markdown-body a { color: #8fb3ff; text-decoration: underline; }
.chat-form {
  padding: 16px;
  display: grid;
  gap: 12px;
  flex: 0 0 auto;
}
#messageInput { resize: vertical; min-height: 150px; max-height: 260px; }
.chat-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.chat-loading-note { min-height: 20px; color: var(--muted); font-size: 13px; }
.loading-button {
  min-width: 150px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}
.button-spinner {
  width: 16px;
  height: 16px;
  border-radius: 999px;
  border: 2px solid rgba(255,255,255,0.28);
  border-top-color: #ffffff;
  display: none;
  animation: spin 0.85s linear infinite;
}
.chat-form.loading .button-spinner { display: inline-block; }
.typing-indicator {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-height: 22px;
  margin-top: 10px;
}
.typing-indicator span {
  width: 9px;
  height: 9px;
  border-radius: 999px;
  background: rgba(143, 179, 255, 0.85);
  animation: typingBounce 1.1s infinite ease-in-out;
}
.typing-indicator span:nth-child(2) { animation-delay: 0.15s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.3s; }
@keyframes spin { to { transform: rotate(360deg); } }
@keyframes typingBounce {
  0%, 80%, 100% { transform: scale(0.75); opacity: 0.45; }
  40% { transform: scale(1); opacity: 1; }
}
@media (max-width: 1400px) {
  .page-grid {
    grid-template-columns: 220px minmax(0, 1.2fr) minmax(320px, 0.88fr);
  }
}
@media (max-width: 1080px) {
  html, body { overflow: auto; }
  .app-shell { height: auto; overflow: visible; }
  .page-grid { grid-template-columns: 1fr; height: auto; }
  .panel { min-height: auto; }
  .session-list, .chat-thread, .event-stream { max-height: 420px; }
}
