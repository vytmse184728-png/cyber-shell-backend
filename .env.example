SECRET_KEY=change-me
API_KEY=replace-me
GEMINI_API_KEY=replace-with-your-google-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1beta
DATABASE_URL=postgresql+psycopg://cyber:cyber@db:5432/cyber_shell
APP_PORT=60081

# Single fixed base URL used by the HTTP tool. The model cannot override this.
HTTP_TOOL_TARGET_URL=http://172.16.255.112

# Host header values the model is allowed to use.
HTTP_TOOL_ALLOWED_HOSTS=cmd.lab.local,sql.lab.local,idor.lab.local

# Keep this broad if you want the model to verify POST/PUT/PATCH style flows.
HTTP_TOOL_ALLOWED_METHODS=GET,HEAD,POST,PUT,PATCH,DELETE,OPTIONS
HTTP_TOOL_TIMEOUT_SECONDS=5
MAX_TOOL_ROWS=20
MAX_OUTPUT_PREVIEW_CHARS=1200
